# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Node.js
node_modules/

# Tauri auto-generated files
src-tauri/gen/

# Build output (frontend)
dist/

# Build output (pre-built binaries)
dist-linux/
dist-windows-arm64/
dist-windows-x86_64/

# Packaged archives
*.zip
*.tar.gz

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db
